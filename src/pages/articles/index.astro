---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allArticles = (await getCollection('articles')).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

// 全タグを収集
const allTags = [...new Set(allArticles.flatMap(a => a.data.tags))].sort();

// 検索用データ
const searchData = allArticles.map(a => ({
  id: a.id,
  title: a.data.title,
  date: a.data.date,
  tags: a.data.tags,
  category: a.data.category,
  summary: a.data.summary,
  thumbnail: a.data.thumbnail,
}));
---

<BaseLayout title="記事一覧" currentTab="articles">
  <div class="page-header">
    <h1 style="color: var(--c-purple);">📰 記事一覧</h1>
    <p class="subtitle">ゲーム分析・企画コラム・制作記録などの記事です</p>
  </div>

  <!-- 検索 -->
  <div class="search-box">
    <input type="text" class="search-input" id="article-search" placeholder="🔍 記事を検索..." />
  </div>

  <!-- タグフィルター -->
  <div class="tag-filter" id="tag-filter">
    <button class="tag-filter-btn active" data-tag="all">すべて</button>
    {allTags.map(tag => (
      <button class="tag-filter-btn" data-tag={tag}>{tag}</button>
    ))}
  </div>

  <!-- 記事一覧 -->
  <div class="card-grid" id="article-list">
    {allArticles.map((article) => (
      <a href={`/articles/${article.id}/`} class="card article-card" style="text-decoration:none;color:inherit;"
         data-tags={JSON.stringify(article.data.tags)}
         data-title={article.data.title}
         data-summary={article.data.summary}>
        <div class="card-thumb" style="background: linear-gradient(135deg, var(--c-purple), var(--c-pink));display:flex;align-items:center;justify-content:center;font-size:2rem;">📰</div>
        <div class="card-body">
          <div style="font-size:0.8rem;color:var(--text-muted);margin-bottom:0.2rem;">{article.data.date} / {article.data.category}</div>
          <h3 class="card-title">{article.data.title}</h3>
          <p class="card-summary">{article.data.summary}</p>
          <div class="card-meta">
            {article.data.tags.map((tag) => {
              const colors = ['pink', 'orange', 'green', 'blue', 'purple', 'cyan'];
              const color = colors[tag.length % colors.length];
              return <span class="tag" data-color={color}>{tag}</span>;
            })}
          </div>
        </div>
      </a>
    ))}
  </div>

  <div class="empty-state" id="no-results" style="display:none;">
    該当する記事が見つかりませんでした。
  </div>

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const searchInput = document.getElementById('article-search') as HTMLInputElement;
      const tagFilter = document.getElementById('tag-filter')!;
      const articleList = document.getElementById('article-list')!;
      const noResults = document.getElementById('no-results')!;
      const cards = Array.from(articleList.querySelectorAll('.article-card')) as HTMLElement[];

      let activeTag = 'all';

      function filterArticles() {
        const query = searchInput.value.toLowerCase().trim();
        let visibleCount = 0;

        cards.forEach(card => {
          const title = (card.getAttribute('data-title') || '').toLowerCase();
          const summary = (card.getAttribute('data-summary') || '').toLowerCase();
          const tags: string[] = JSON.parse(card.getAttribute('data-tags') || '[]');

          const matchesTag = activeTag === 'all' || tags.includes(activeTag);
          const matchesSearch = !query || title.includes(query) || summary.includes(query) || tags.some(t => t.toLowerCase().includes(query));

          if (matchesTag && matchesSearch) {
            card.style.display = '';
            visibleCount++;
          } else {
            card.style.display = 'none';
          }
        });

        noResults.style.display = visibleCount === 0 ? '' : 'none';
      }

      searchInput.addEventListener('input', filterArticles);

      tagFilter.addEventListener('click', (e) => {
        const btn = (e.target as HTMLElement).closest('.tag-filter-btn') as HTMLElement;
        if (!btn) return;
        activeTag = btn.getAttribute('data-tag') || 'all';
        tagFilter.querySelectorAll('.tag-filter-btn').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        filterArticles();
      });
    });
  </script>
</BaseLayout>
